---
import { Picture, Image } from 'astro:assets';
import heroCover from '../assets/images/hero-cover.jpg';
import logo from '../assets/images/logo.jpg';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-forest-950">
  <!-- Cover photo background -->
  <div class="absolute inset-0">
    <Picture
      src={heroCover}
      widths={[640, 828, 1080, 1536]}
      formats={['webp']}
      alt=""
      class="w-full h-full object-cover opacity-40"
      loading="eager"
      fetchpriority="high"
      layout="full-width"
    />
  </div>

  <!-- Gradient overlays -->
  <div class="absolute inset-0 bg-gradient-to-b from-forest-950/80 via-forest-900/60 to-forest-950/90"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-forest-950/50 via-transparent to-forest-950/50"></div>

  <!-- Ground fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-forest-950 to-transparent z-10"></div>

  <!-- Content -->
  <div class="relative z-20 text-center px-4 max-w-4xl mx-auto">
    <!-- Real logo image -->
    <div class="mb-8 inline-block animate-float">
      <Image
        src={logo}
        width={352}
        densities={[1, 2]}
        format="webp"
        alt="Vojta Koutský - Arboristika logo"
        class="w-36 h-36 sm:w-44 sm:h-44 mx-auto rounded-3xl shadow-2xl border-2 border-forest-400/30 object-cover"
        loading="eager"
      />
    </div>

    <h1 class="font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold text-white text-shadow-hero leading-tight mb-6">
      Vojta Koutský
      <span class="block text-forest-400 text-2xl sm:text-3xl md:text-4xl font-bold mt-2">
        Váš arborista v Kutné Hoře
      </span>
    </h1>

    <p class="text-lg sm:text-xl text-forest-200/90 max-w-2xl mx-auto mb-4 leading-relaxed">
      Starám se o stromy na Kutnohorsku od roku 2018. Odborně, bezpečně a s respektem.
    </p>
    <p class="text-base sm:text-lg text-forest-300/70 mb-10">
      Kutná Hora a Středočeský kraj
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="tel:+420606535475"
        class="group px-8 py-4 bg-forest-400 hover:bg-forest-300 text-forest-950 font-bold rounded-full text-lg transition-all duration-300 shadow-lg hover:shadow-2xl hover:scale-105 flex items-center gap-3"
      >
        <svg class="w-5 h-5 group-hover:animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        606 535 475
      </a>
      <a
        href="#sluzby"
        class="px-8 py-4 border-2 border-forest-400/50 text-forest-200 hover:bg-forest-400/10 hover:border-forest-400 font-semibold rounded-full text-lg transition-all duration-300"
      >
        Moje služby
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 animate-bounce">
    <svg class="w-6 h-6 text-forest-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>

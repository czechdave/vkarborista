---
// Decorative falling leaves animation overlay
---

<div class="fixed inset-0 pointer-events-none z-50 overflow-hidden" aria-hidden="true" id="falling-leaves">
  {Array.from({ length: 12 }).map((_, i) => (
    <div
      class="absolute animate-fall opacity-0"
      style={`left: ${Math.random() * 100}%; animation-duration: ${8 + Math.random() * 12}s; animation-delay: ${Math.random() * 10}s;`}
    >
      <svg
        width={12 + Math.random() * 14}
        height={12 + Math.random() * 14}
        viewBox="0 0 24 24"
        class="animate-sway"
        style={`animation-duration: ${2 + Math.random() * 3}s; color: ${['#22c55e', '#16a34a', '#4ade80', '#15803d', '#86efac'][Math.floor(Math.random() * 5)]};`}
      >
        <path
          d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.95-2.3c.48.17.98.3 1.34.3C19 20 22 3 22 3c-1 2-8 2.25-13 3.25S2 11.5 2 13.5s1.75 3.75 1.75 3.75C7 8 17 8 17 8z"
          fill="currentColor"
        />
      </svg>
    </div>
  ))}
</div>

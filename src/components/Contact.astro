---
// Contact section
---

<section id="kontakt" class="relative py-24 sm:py-32 bg-white bark-texture overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16 sm:mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-forest-100 text-forest-700 text-sm font-medium mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        Kontakt
      </div>
      <h2 class="font-display text-4xl sm:text-5xl font-bold text-forest-900 mb-6">
        Ozvěte se nám
      </h2>
      <p class="text-lg text-forest-600 max-w-2xl mx-auto">
        Máte strom, který potřebuje péči? Neváhejte nás kontaktovat.
        Rádi vám poradíme a připravíme cenovou nabídku.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
      <!-- Phone card -->
      <a
        href="tel:+420606535475"
        class="group relative bg-gradient-to-br from-forest-500 to-forest-700 rounded-3xl p-8 text-white shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 hover:scale-[1.02] overflow-hidden"
      >
        <!-- Decorative leaf -->
        <div class="absolute -top-4 -right-4 w-24 h-24 opacity-10 group-hover:opacity-20 transition-opacity" aria-hidden="true">
          <svg viewBox="0 0 100 100" fill="white">
            <path d="M50 5 C25 15 5 45 10 75 C15 95 40 98 50 98 C60 98 85 95 90 75 C95 45 75 15 50 5Z"/>
          </svg>
        </div>
        <div class="w-16 h-16 rounded-2xl bg-white/20 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
        </div>
        <h3 class="font-display text-xl font-bold mb-2">Telefon</h3>
        <p class="text-2xl font-bold text-forest-100 group-hover:text-white transition-colors">
          606 535 475
        </p>
        <p class="text-forest-200/70 mt-2 text-sm">Klikněte pro zavolání</p>
      </a>

      <!-- Email card -->
      <a
        href="mailto:citac@seznam.cz"
        class="group relative bg-gradient-to-br from-forest-600 to-forest-800 rounded-3xl p-8 text-white shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 hover:scale-[1.02] overflow-hidden"
      >
        <div class="absolute -top-4 -right-4 w-24 h-24 opacity-10 group-hover:opacity-20 transition-opacity" aria-hidden="true">
          <svg viewBox="0 0 100 100" fill="white">
            <path d="M50 5 C25 15 5 45 10 75 C15 95 40 98 50 98 C60 98 85 95 90 75 C95 45 75 15 50 5Z"/>
          </svg>
        </div>
        <div class="w-16 h-16 rounded-2xl bg-white/20 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <h3 class="font-display text-xl font-bold mb-2">E-mail</h3>
        <p class="text-xl font-bold text-forest-100 group-hover:text-white transition-colors break-all">
          citac@seznam.cz
        </p>
        <p class="text-forest-200/70 mt-2 text-sm">Klikněte pro odeslání emailu</p>
      </a>

      <!-- Location card -->
      <div class="group relative bg-gradient-to-br from-forest-700 to-forest-900 rounded-3xl p-8 text-white shadow-xl overflow-hidden">
        <div class="absolute -top-4 -right-4 w-24 h-24 opacity-10" aria-hidden="true">
          <svg viewBox="0 0 100 100" fill="white">
            <path d="M50 5 C25 15 5 45 10 75 C15 95 40 98 50 98 C60 98 85 95 90 75 C95 45 75 15 50 5Z"/>
          </svg>
        </div>
        <div class="w-16 h-16 rounded-2xl bg-white/20 flex items-center justify-center mb-6">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <h3 class="font-display text-xl font-bold mb-2">Oblast působnosti</h3>
        <p class="text-xl font-bold text-forest-100">
          Středočeský kraj
        </p>
        <p class="text-forest-200/70 mt-2 text-sm">Kutná Hora a blízké okolí</p>
      </div>
    </div>

    <!-- Facebook CTA -->
    <div class="mt-16 text-center">
      <div class="inline-flex flex-col sm:flex-row items-center gap-4 sm:gap-6 p-6 sm:p-8 rounded-3xl bg-forest-50 border border-forest-200">
        <div class="w-14 h-14 rounded-full bg-blue-600 flex items-center justify-center flex-shrink-0">
          <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </div>
        <div class="text-center sm:text-left">
          <p class="font-display font-bold text-forest-900 text-lg">Sledujte nás na Facebooku</p>
          <p class="text-forest-600 text-sm mt-1">Novinky, fotky z terénu a aktuální informace</p>
        </div>
        <a
          href="https://www.facebook.com/people/Vojta-Koutsk%C3%BD-Arboristika/61555456270844/"
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-full font-semibold transition-all duration-300 hover:shadow-lg flex-shrink-0"
        >
          Navštívit stránku
        </a>
      </div>
    </div>
  </div>
</section>

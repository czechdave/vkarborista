---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const images = import.meta.glob<{ default: ImageMetadata }>('../assets/images/galerie/*.jpg', { eager: true });

function resolve(filename: string) {
  const path = `../assets/images/galerie/${filename}`;
  const img = images[path];
  if (!img) throw new Error(`Gallery image not found: ${filename}`);
  return img.default;
}

const rawGalleryItems = [
  { file: "01-stromolezeni.jpg", title: "Práce ve výškách", desc: "Stromolezení u elektrického vedení", alt: "Arborista při stromolezení u elektrického vedení v Kutné Hoře" },
  { file: "02-tym.jpg", title: "Týmová spolupráce", desc: "Rojení arboristů v korunách stromů", alt: "Tým arboristů při ořezu v korunách stromů" },
  { file: "03-selfie.jpg", title: "Pohled z koruny", desc: "Selfie z pracoviště vysoko nad zemí", alt: "Arborista Vojta Koutský při práci vysoko v koruně stromu" },
  { file: "04-pohled-zhora.jpg", title: "Pohled shora", desc: "Řízené spouštění větví", alt: "Řízené spouštění větví při ořezu stromu — pohled shora" },
  { file: "05-kaceni-smrku.jpg", title: "Kácení smrku", desc: "Zpracování velkého jehličnanu u domu", alt: "Rizikové kácení velkého smrku u rodinného domu" },
  { file: "06-zpracovani.jpg", title: "Zpracování dřeva", desc: "Odborné rozřezání kmene na hřbitově", alt: "Odborné zpracování pokáceného kmene motorovou pilou" },
  { file: "07-letecky.jpg", title: "Letecký pohled", desc: "Pohled z výšky na pracoviště", alt: "Letecký pohled na arboristické pracoviště v Kutné Hoře" },
];

const galleryItems = await Promise.all(
  rawGalleryItems.map(async (item) => {
    const src = resolve(item.file);
    const lightbox = await getImage({ src, width: 1200, format: 'webp' });
    return { ...item, src, lightboxSrc: lightbox.src };
  })
);
---

<section id="galerie" class="relative py-24 sm:py-32 bg-forest-50 overflow-hidden">
  <!-- Decorative leaf -->
  <div class="absolute top-10 left-10 opacity-5" aria-hidden="true">
    <svg class="w-64 h-64 animate-sway-slow" viewBox="0 0 200 200" fill="#166534">
      <path d="M100 10 C60 30 20 80 30 140 C40 180 80 190 100 190 C120 190 160 180 170 140 C180 80 140 30 100 10Z"/>
      <line x1="100" y1="10" x2="100" y2="190" stroke="#052e16" stroke-width="2"/>
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16 sm:mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-forest-100 text-forest-700 text-sm font-medium mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        Galerie
      </div>
      <h2 class="font-display text-4xl sm:text-5xl font-bold text-forest-900 mb-6">
        Práce v terénu
      </h2>
      <p class="text-lg text-forest-600 max-w-2xl mx-auto">
        Pár fotek z terénu. Každá zakázka je jiná — podívejte se, jak to vypadá v praxi.
      </p>
    </div>

    <!-- Gallery grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
      {galleryItems.map((item, i) => (
        <div
          class:list={[
            "group relative rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-1 cursor-pointer",
            i === 0 || i === 7 ? "sm:col-span-2 aspect-[16/9]" : "aspect-[4/3]",
          ]}
          data-lightbox-src={item.lightboxSrc}
          data-lightbox-title={item.title}
          data-lightbox-type="gallery"
        >
          <Image
            src={item.src}
            widths={[400, 640, 828]}
            sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
            format="webp"
            alt={item.alt}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent opacity-80 group-hover:opacity-100 transition-opacity"></div>
          <!-- Content -->
          <div class="absolute inset-0 flex flex-col justify-end p-5 sm:p-6">
            <h3 class="font-display text-lg sm:text-xl font-bold text-white mb-1 group-hover:translate-x-1 transition-transform">
              {item.title}
            </h3>
            <p class="text-white/70 text-sm leading-relaxed">
              {item.desc}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Facebook link -->
    <div class="text-center mt-12">
      <a
        href="https://www.facebook.com/people/Vojta-Koutsk%C3%BD-Arboristika/61555456270844/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 px-8 py-4 bg-forest-800 hover:bg-forest-700 text-white rounded-full font-semibold transition-all duration-300 hover:shadow-lg hover:scale-105"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
        Více fotek na Facebooku
      </a>
    </div>
  </div>
</section>

---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Arborista Kutná Hora | Vojta Koutský – Ořez stromů a rizikové kácení",
  description = "Profesionální ořez stromů, rizikové kácení a péče o zeleň v Kutné Hoře a okolí. Vojta Koutský — arborista s praxí od roku 2018. Zavolejte 606 535 475."
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/images/hero-cover.jpg', Astro.site);
---

<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#052e16" />
    <meta name="description" content={description} />
    <meta name="keywords" content="arborista Kutná Hora, ořez stromů, kácení stromů, rizikové kácení, arborista Středočeský kraj, péče o stromy, Kutná Hora, Středočeský kraj, zdravotní řez, bezpečnostní řez, ořez korun, arboristika" />
    <meta name="author" content="Vojta Koutský" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Geo tags -->
    <meta name="geo.region" content="CZ-20" />
    <meta name="geo.placename" content="Kutná Hora" />
    <meta name="geo.position" content="49.9481;15.2683" />
    <meta name="ICBM" content="49.9481, 15.2683" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1536" />
    <meta property="og:image:height" content="2048" />
    <meta property="og:locale" content="cs_CZ" />
    <meta property="og:site_name" content="Vojta Koutský – Arboristika" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://vkarborista.cz/#website",
          "name": "Vojta Koutský — Arboristika",
          "url": "https://vkarborista.cz",
